// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// TENANT / MERCHANT
// ============================================
model Merchant {
  id           String    @id @default(uuid())
  name         String
  slug         String    @unique
  logo_url     String?
  address      String?
  phone        String?
  email        String?
  tax_id       String?
  subscription String?   @default("trial")
  is_active    Boolean?  @default(true)
  settings     String?   @default("{}")
  created_at   DateTime? @default(now())
  updated_at   DateTime? @default(now())

  stores         Store[]
  roles          Role[]
  users          User[]
  categories     Category[]
  units          Unit[]
  brands         Brand[]
  products       Product[]
  customerGroups CustomerGroup[]
  customers      Customer[]

  @@map("merchants")
}

// ============================================
// STORE / CABANG
// ============================================
model Store {
  id          String    @id @default(uuid())
  merchant_id String
  merchant    Merchant  @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  code        String
  name        String
  address     String?
  phone       String?
  email       String?
  timezone    String?   @default("Asia/Jakarta")
  is_active   Boolean?  @default(true)
  settings    String?   @default("{}")
  created_at  DateTime? @default(now())
  updated_at  DateTime? @default(now())

  users       User[]
  inventories Inventory[]
  Transaction Transaction[]

  @@unique([merchant_id, code])
  @@map("stores")
}

// ============================================
// ROLES
// ============================================
model Role {
  id          String    @id @default(uuid())
  merchant_id String
  merchant    Merchant  @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  name        String
  permissions String    @default("[]")
  is_system   Boolean?  @default(false)
  created_at  DateTime? @default(now())

  users User[]

  @@unique([merchant_id, name])
  @@map("roles")
}

// ============================================
// USERS
// ============================================
model User {
  id          String   @id @default(uuid())
  merchant_id String
  merchant    Merchant @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  role_id     String
  role        Role     @relation(fields: [role_id], references: [id])
  store_id    String?
  store       Store?   @relation(fields: [store_id], references: [id])

  name               String
  email              String?
  phone              String?
  pin                String?
  password_hash      String?
  avatar_url         String?
  is_active          Boolean?      @default(true)
  last_login_at      DateTime?
  last_login_ip      String?
  failed_attempts    Int?          @default(0)
  locked_until       DateTime?
  two_factor_enabled Boolean?      @default(false)
  two_factor_secret  String?
  created_at         DateTime?     @default(now())
  updated_at         DateTime?     @default(now())
  Transaction        Transaction[]

  @@unique([merchant_id, email])
  @@map("users")
}

// ============================================
// CATEGORIES
// ============================================
model Category {
  id          String     @id @default(uuid())
  merchant_id String
  merchant    Merchant   @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  parent_id   String?
  parent      Category?  @relation("CategoryToCategory", fields: [parent_id], references: [id])
  children    Category[] @relation("CategoryToCategory")

  name        String
  slug        String
  description String?
  image_url   String?
  sort_order  Int?      @default(0)
  is_active   Boolean?  @default(true)
  created_at  DateTime? @default(now())
  updated_at  DateTime? @default(now())

  products Product[]

  @@unique([merchant_id, slug])
  @@map("categories")
}

// ============================================
// UNITS
// ============================================
model Unit {
  id          String    @id @default(uuid())
  merchant_id String
  merchant    Merchant  @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  name        String
  symbol      String?
  created_at  DateTime? @default(now())

  products Product[]

  @@unique([merchant_id, name])
  @@map("units")
}

// ============================================
// BRANDS
// ============================================
model Brand {
  id          String    @id @default(uuid())
  merchant_id String
  merchant    Merchant  @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  name        String
  image_url   String?
  is_active   Boolean?  @default(true)
  created_at  DateTime? @default(now())

  products Product[]

  @@unique([merchant_id, name])
  @@map("brands")
}

// ============================================
// PRODUCTS
// ============================================
model Product {
  id          String    @id @default(uuid())
  merchant_id String
  merchant    Merchant  @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  category_id String?
  category    Category? @relation(fields: [category_id], references: [id])
  brand_id    String?
  brand       Brand?    @relation(fields: [brand_id], references: [id])
  unit_id     String?
  unit        Unit?     @relation(fields: [unit_id], references: [id])

  sku         String
  barcode     String?
  name        String
  slug        String?
  description String?
  image_urls  String?   @default("[]")

  cost_price      Decimal? @default(0)
  selling_price   Decimal? @default(0)
  wholesale_price Decimal? @default(0)
  member_price    Decimal? @default(0)

  track_inventory Boolean? @default(true)
  has_variant     Boolean? @default(false)
  has_batch       Boolean? @default(false)
  is_service      Boolean? @default(false)
  is_active       Boolean? @default(true)
  tax_rate        Decimal? @default(0)

  min_stock     Decimal? @default(0)
  max_stock     Decimal? @default(0)
  reorder_point Decimal? @default(0)

  weight    Decimal?
  dimension String?
  tags      String?   @default("[]")

  created_at DateTime? @default(now())
  updated_at DateTime? @default(now())

  inventories     Inventory[]
  TransactionItem TransactionItem[]

  @@unique([merchant_id, sku])
  @@index([merchant_id, barcode])
  @@map("products")
}

// ============================================
// INVENTORY
// ============================================
model Inventory {
  id           String    @id @default(uuid())
  store_id     String
  store        Store     @relation(fields: [store_id], references: [id], onDelete: Cascade)
  product_id   String
  product      Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  variant_id   String?
  batch_number String?
  expiry_date  DateTime?

  stock_on_hand  Decimal? @default(0)
  stock_reserved Decimal? @default(0)
  avg_cost       Decimal? @default(0)

  last_counted_at DateTime?
  updated_at      DateTime? @default(now())

  @@unique([store_id, product_id, variant_id, batch_number])
  @@map("inventory")
}

// ============================================
// CUSTOMER GROUPS
// ============================================
model CustomerGroup {
  id                String    @id @default(uuid())
  merchant_id       String
  merchant          Merchant  @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  name              String
  discount_percent  Decimal?  @default(0)
  points_multiplier Decimal?  @default(1.0)
  created_at        DateTime? @default(now())

  customers Customer[]

  @@unique([merchant_id, name])
  @@map("customer_groups")
}

// ============================================
// CUSTOMERS
// ============================================
model Customer {
  id          String         @id @default(uuid())
  merchant_id String
  merchant    Merchant       @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  group_id    String?
  group       CustomerGroup? @relation(fields: [group_id], references: [id])
  store_id    String?

  code       String?
  name       String
  phone      String?
  email      String?
  address    String?
  gender     String?
  birth_date DateTime?
  notes      String?

  total_points   Int?      @default(0)
  total_spent    Decimal?  @default(0)
  total_visits   Int?      @default(0)
  last_visit_at  DateTime?
  credit_limit   Decimal?  @default(0)
  credit_balance Decimal?  @default(0)

  is_active   Boolean?      @default(true)
  created_at  DateTime?     @default(now())
  updated_at  DateTime?     @default(now())
  Transaction Transaction[]

  @@index([merchant_id, phone])
  @@index([merchant_id, code])
  @@map("customers")
}

// ============================================
// TRANSACTIONS (POS)
// ============================================
model Transaction {
  id          String    @id @default(uuid())
  store_id    String
  store       Store     @relation(fields: [store_id], references: [id], onDelete: Cascade)
  user_id     String?
  user        User?     @relation(fields: [user_id], references: [id])
  customer_id String?
  customer    Customer? @relation(fields: [customer_id], references: [id])

  invoice_number   String   @unique
  transaction_date DateTime @default(now())

  // Financial
  subtotal       Decimal? @default(0)
  discount_total Decimal? @default(0)
  tax_total      Decimal? @default(0)
  grand_total    Decimal? @default(0)
  paid_amount    Decimal? @default(0)
  change_amount  Decimal? @default(0)
  payment_method String?

  status String? @default("completed")

  created_at DateTime? @default(now())
  updated_at DateTime? @default(now())

  items TransactionItem[]

  @@map("transactions")
}

model TransactionItem {
  id             String      @id @default(uuid())
  transaction_id String
  transaction    Transaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  product_id     String
  product        Product     @relation(fields: [product_id], references: [id])

  quantity   Decimal
  unit_price Decimal
  subtotal   Decimal

  created_at DateTime? @default(now())

  @@map("transaction_items")
}
