# Konfigurasi Database MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=kasirpro_db

# Connection URL untuk ORM (misal: Prisma, Sequelize, Drizzle)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:@127.0.0.1:3306/kasirpro_db"

# Konfigurasi Aplikasi / Frontend (Vite)
VITE_API_URL=http://localhost:3000/api
VITE_APP_NAME="KasirPro"
VITE_APP_ENV=development
